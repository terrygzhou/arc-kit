# Legacy local directories (no longer generated)
.codex/
.opencode/
.agents/skills/
.claude/worktrees/


# ── Generated distribution formats ────────────────────────────────────────────
# arckit-claude is the single source of truth. The non-Claude extension formats
# below are regenerated by scripts/converter.py (commands/prompts/agents/skills/
# templates/docs-guides/config/schemas/references/scripts/hooks) and published to
# their own GitHub repos by scripts/push-extensions.sh, which tars the working
# tree from disk (not git), so generated content does NOT need to be tracked.
# Only hand-authored files are tracked here: README/VERSION/LICENSE, the platform
# manifests (config.toml, opencode.json, gemini-extension.json, package.json),
# hand-maintained hooks (codex .mjs, gemini hooks/scripts/*.py), paperclip TS
# source, and each docs/DEPENDENCY-MATRIX.md. Regenerate locally before release.
# See CLAUDE.md "Generated extension formats are not tracked".

# -- extensions/arckit-codex (generated) --
extensions/arckit-codex/commands/
extensions/arckit-codex/prompts/
extensions/arckit-codex/agents/
extensions/arckit-codex/skills/
extensions/arckit-codex/templates/
extensions/arckit-codex/docs/guides/
extensions/arckit-codex/config/
extensions/arckit-codex/schemas/
extensions/arckit-codex/references/
extensions/arckit-codex/scripts/
extensions/arckit-codex/.codex-plugin/
extensions/arckit-codex/config.toml
extensions/arckit-codex/.mcp.json
extensions/arckit-codex/hooks/owm-tidy.mjs
extensions/arckit-codex/hooks/wardley-label-placement.mjs

# -- extensions/arckit-opencode (generated) --
extensions/arckit-opencode/commands/
extensions/arckit-opencode/agents/
