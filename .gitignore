tools/wardley-lsp/

# Ignyte scraper - captured session token (never commit)
docs/auth.txt

# Investor pitch decks - confidential fundraising material.
# arc-kit is a public repo; the decks, scraped investor data (with PII),
# scraper config/tokens, and generator scripts must never be committed.
docs/pitch-decks/
docs/2026-05-20-difc-innovation-licence-setup-guide.pdf

# Partnership/funding proposals - confidential business material, kept off the
# public repo (same rationale as pitch-decks above).
docs/proposals/

# LinkedIn data export - contains personal PII (connections, messages, phone)
docs/*LinkedInDataExport*

# arckit-consulting/ is a clone of the separate tractorjuice/arckit-fde repo.
